# ── Server ──────────────────────────────────────────────────
PORT=3001

# ── Security ─────────────────────────────────────────────────
# Generate a strong random string: openssl rand -base64 64
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# ── Frontend URL (for Stripe redirect URLs) ──────────────────
# Set this to your Vercel URL once deployed, e.g. https://truenorthpm.vercel.app
FRONTEND_URL=http://localhost:5173

# ── CORS ─────────────────────────────────────────────────────
# Set to your Vercel URL once deployed
CORS_ORIGIN=http://localhost:5173

# ── Stripe ───────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=whsec_...

# ── Database ─────────────────────────────────────────────────
# Optional: defaults to ./data/property_manager.db
# DATABASE_PATH=/data/property_manager.db
